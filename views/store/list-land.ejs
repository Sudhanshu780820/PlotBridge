<%-include('../partials/head') %>
    

    <main class="container mx-auto px-4 py-12">
      <%-include('../partials/nav') %>
      <div
        class="max-w-2xl mx-auto bg-white shadow-xl rounded-3xl overflow-hidden"
      >
        <div class="bg-emerald-600 px-8 py-10 text-white">
          <h1 class="text-3xl font-bold">List Your Property</h1>
          <p class="text-emerald-100 mt-2">
            Fill in the details below to reach thousands of potential buyers.
          </p>
        </div>

        <form
          action="/list-land"
          method="POST"
          class="p-8 space-y-6"
          enctype="multipart/form-data"
        >
          <!-- Property Title -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2"
              >Property Title</label
            >
            <input
              type="text"
              name="LandName"
              placeholder="e.g. 5 Acre Organic Farm"
              required
              class="w-full px-4 py-3 rounded-xl border border-slate-100 focus:ring-2 focus:ring-emerald-500 focus:outline-none transition"
            />
          </div>

          <!-- Price and Category Row -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2"
                >Asking Price</label
              >
              <div class="flex">
                <input
                  type="number"
                  name="price"
                  step="any"
                  placeholder="Amount"
                  required
                  class="w-full px-4 py-3 rounded-l-xl border border-slate-200 focus:ring-2 focus:ring-emerald-500 focus:outline-none"
                />
                <select
                  name="priceUnit"
                  class="px-3 rounded-r-xl border border-l-0 border-slate-200 bg-slate-50 text-slate-600 font-semibold focus:outline-none cursor-pointer"
                >
                  <option value="Rupees">₹ Rupees</option>
                  <option value="Lakh">Lakh</option>
                  <option value="Crore">Crore</option>
                  <option value="Dollar">$ Dollar</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2"
                >Land Category</label
              >
              <select
                name="category"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none"
              >
                <option>Residential</option>
                <option>Agricultural</option>
                <option>Commercial</option>
                <option>Industrial</option>
              </select>
            </div>
          </div>

          <!-- Size and Location Row -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2"
                >Land Size (Area)</label
              >
              <div class="flex">
                <input
                  type="number"
                  name="LandSize"
                  placeholder="e.g. 2400"
                  required
                  class="w-full px-4 py-3 rounded-l-xl border border-slate-200 focus:ring-2 focus:ring-emerald-500 focus:outline-none"
                />
                <select
                  name="sizeUnit"
                  class="px-3 rounded-r-xl border border-l-0 border-slate-200 bg-slate-50 text-slate-600 font-semibold focus:outline-none cursor-pointer"
                >
                  <option value="Sqft">Sq. Ft.</option>
                  <option value="Acre">Acre</option>
                  <option value="Bigha">Bigha</option>
                  <option value="Hectare">Hectare</option>
                </select>
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-2"
                >Exact Location</label
              >
              <input
                type="text"
                name="location"
                placeholder="City, Area, or Landmark"
                required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-emerald-500 focus:outline-none"
              />
            </div>
          </div>

          <!-- Detailed Description -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2"
              >Detailed Description</label
            >
            <textarea
              name="description"
              rows="4"
              placeholder="Describe the soil, water availability, road access, etc."
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-emerald-500 focus:outline-none"
            ></textarea>
          </div>

          <!-- Image Upload -->
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2"
              >Property Photo</label
            >
            <input
              type="file"
              name="photo"
              accept="image/jpeg, image/png, image/jpg"
              required
              class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100 cursor-pointer"
            />
          </div>
           <div>
    <label class="block text-sm font-bold text-slate-700 mb-2">Pin Exact Location</label>
    <div id="mapInput" class="h-64 rounded-2xl mb-4 border-2 border-slate-100"></div>
    
    <!-- Hidden inputs to send coordinates to the backend -->
    <input type="hidden" name="lat" id="latInput">
    <input type="hidden" name="lng" id="lngInput">
</div>

          <div class="pt-4">
            <button
              type="submit"
              class="w-full bg-emerald-600 text-white font-bold py-4 rounded-xl hover:bg-emerald-700 shadow-lg shadow-emerald-200 transition transform hover:-translate-y-1"
            >
              Publish Listing
            </button>
          </div>
         

<script>
    // 1. Initialize map (Centered on India by default)
    var map = L.map('mapInput').setView([20.5937, 78.9629], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    var marker;

    // 2. Function to place/move marker and update hidden inputs
    map.on('click', function(e) {
        if (marker) {
            marker.setLatLng(e.latlng);
        } else {
            marker = L.marker(e.latlng, {draggable: true}).addTo(map);
        }
        document.getElementById('latInput').value = e.latlng.lat;
        document.getElementById('lngInput').value = e.latlng.lng;
    });
</script>
        </form>
      </div>
    </main>

    <footer class="text-center py-10 text-slate-400 text-sm">
      &copy; 2026 TerraSale | Secure Land Transactions
    </footer>
  </body>
</html>
