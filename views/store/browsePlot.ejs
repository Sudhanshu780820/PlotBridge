<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<body class="bg-slate-50 font-sans antialiased">

  <main class="pt-32 pb-20 px-4 max-w-7xl mx-auto">
    
    <div class="bg-white p-4 rounded-3xl shadow-sm border border-slate-100 mb-10 flex flex-col md:flex-row gap-4 items-center justify-between">
      <div class="relative w-full md:w-96">
        <input type="text" placeholder="Search by city or area..." 
          class="w-full pl-12 pr-4 py-3 bg-slate-50 border-none rounded-2xl text-sm focus:ring-2 focus:ring-emerald-500 transition-all">
        <svg class="w-5 h-5 text-slate-400 absolute left-4 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>

      <div class="flex gap-2 w-full md:w-auto">
        <select class="flex-grow md:flex-grow-0 bg-slate-50 border-none rounded-xl px-4 py-3 text-sm font-bold text-slate-600 focus:ring-2 focus:ring-emerald-500">
          <option>All Types</option>
          <option>Residential</option>
          <option>Agricultural</option>
          <option>Commercial</option>
        </select>
        <button class="bg-emerald-600 text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-emerald-700 transition shadow-lg shadow-emerald-100">
          Filter
        </button>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-3xl font-black text-slate-800 tracking-tight">Available Plots</h2>
      <p class="text-slate-100 font-medium">Explore verified land listings across Madhya Pradesh.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      
      <% registeredLand.forEach(plot => { %>
        <div class="group bg-white rounded-[2rem] overflow-hidden border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300">
          
          <div class="relative h-48 overflow-hidden">
            <img src="<%= plot.photo %>" alt="Land Image" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
            <span class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest text-emerald-600">
              <%= plot.category %>
            </span>
          </div>

          <div class="p-6">
            <div class="flex justify-between items-start mb-2">
              <h3 class="font-bold text-slate-800 text-lg leading-tight truncate mr-2"><%= plot.LandName %></h3>
              <div class="bg-emerald-50 p-1 rounded-md">
                <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.64.304 1.25.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
              </div>
            </div>

            <p class="text-slate-500 text-xs flex items-center mb-4">
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
              <%= plot.location %>
            </p>

                   <div class="flex items-center justify-between pt-4 border-t border-slate-50">
  <!-- Price Section -->
  <div>
    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Price</p>
    <p class="text-xl font-black text-emerald-600">
      <%= plot.price %> 
      <span class="text-xs font-bold uppercase text-emerald-700 ml-0.5">
        <%= plot.priceUnit %>
      </span>
    </p>
  </div>

  <!-- Area Section -->
  <div class="text-right">
    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Area</p>
    <p class="text-sm font-bold text-slate-700">
      <%= plot.LandSize %> 
      <span class="text-[10px] font-medium text-slate-400 ml-0.5">
        <%= plot.sizeUnit %>
      </span>
    </p>
  </div>
</div>

            <a href="/plot/<%= plot.id %>" class="block w-full text-center mt-6 py-3 bg-slate-900 text-white rounded-xl font-bold text-sm hover:bg-emerald-600 transition-colors shadow-lg shadow-slate-100">
              View Details
            </a>
          </div>
        </div>
      <% }) %>

    </div>
  </main>


</body>