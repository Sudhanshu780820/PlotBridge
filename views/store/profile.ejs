<%- include('../partials/head') %>
<body class="bg-slate-50 font-sans">
    <%- include('../partials/nav') %>

    <main class="container mx-auto px-4 pt-32 pb-10 max-w-4xl">
        <!-- Profile Header -->
        <div class="bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/60 overflow-hidden border border-slate-100">
            <div class="h-32 bg-gradient-to-r from-emerald-500 to-teal-600"></div>
            <div class="px-8 pb-8">
                <div class="relative flex justify-between items-end -mt-12 mb-6">
                    <div class="w-24 h-24 bg-white rounded-3xl shadow-lg flex items-center justify-center text-3xl font-black text-emerald-600 border-4 border-white">
                        <%= user.firstName[0] %><%= user.lastName[0] %>
                    </div>
                    <a href="/logout" class="bg-red-50 text-red-600 px-6 py-2 rounded-xl text-sm font-bold hover:bg-red-600 hover:text-white transition">
                        Sign Out
                    </a>
                </div>

                <h1 class="text-3xl font-black text-slate-900">
                    <%= user.firstName %> <%= user.lastName %>
                </h1>
                <p class="text-slate-500 font-medium"><%= user.email %></p>
            </div>
        </div>

        <!-- Dashboard Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            <!-- Listing Stats -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm group hover:border-emerald-500 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-3 bg-emerald-50 rounded-2xl text-emerald-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-7h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                    <span class="text-4xl font-black text-slate-900"><%= listCount %></span>
                </div>
                <h3 class="text-lg font-bold text-slate-800">Properties Listed</h3>
                <p class="text-slate-500 text-sm mb-6">Land plots you are currently selling.</p>
                <a href="/host/manage-lands" class="text-emerald-600 font-bold text-sm hover:underline">Manage Listings →</a>
            </div>

            <!-- Enquiry Stats -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm group hover:border-blue-500 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-3 bg-blue-50 rounded-2xl text-blue-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    </div>
                    <span class="text-4xl font-black text-slate-900"><%= enquiryCount %></span>
                </div>
                <h3 class="text-lg font-bold text-slate-800">Enquiries Sent</h3>
                <p class="text-slate-500 text-sm mb-6">Active conversations for land you like.</p>
                <a href="/messages" class="text-blue-600 font-bold text-sm hover:underline">View Messages →</a>
            </div>
        </div>

        <!-- Account Settings Card -->
        <div class="mt-8 bg-slate-900 rounded-[2rem] p-8 text-white relative overflow-hidden">
            <div class="relative z-10">
                <h3 class="text-xl font-bold mb-2">Account Security</h3>
                <p class="text-slate-400 text-sm mb-6">Manage your password and security settings.</p>
                <button class="bg-white/10 hover:bg-white/20 text-white px-6 py-3 rounded-xl font-bold text-sm transition">
                    Update Password
                </button>
            </div>
            <!-- Decorative circle -->
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-emerald-500/20 rounded-full blur-3xl"></div>
        </div>
    </main>
</body>